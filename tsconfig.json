{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"jsx": "preserve",
		"sourceMap": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"skipLibCheck": true,
		"noEmit": true,
		"allowJs": true,
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": ["vite/client"]
	},
	"include": ["src/**/*.ts", "src/**/*.vue", "env.d.ts"],
	"exclude": ["node_modules", "dist", "src/utils/lamejs"]
}
